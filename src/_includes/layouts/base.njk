<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} | {% endif %}{{ site.name }}</title>
    <meta name="description" content="{{ description or summary or site.description }}">
    <link rel="icon" href="{{ '/favicon.svg' | relativeUrl(page.url) }}" type="image/svg+xml">
    <link rel="stylesheet" href="{{ '/assets/css/style.css' | relativeUrl(page.url) }}">
  </head>
  <body>
    <a class="skip-link" href="#contenuto">Salta al contenuto</a>

    <header class="site-header">
      <div class="container header-inner">
        <a class="site-title" href="{{ '/' | relativeUrl(page.url) }}">{{ site.name }}</a>
        <nav class="site-nav" aria-label="Navigazione principale">
          <a href="{{ '/' | relativeUrl(page.url) }}">Home</a>
          <a href="{{ '/storia/' | relativeUrl(page.url) }}">Storia</a>
          <a href="{{ '/avvisi/' | relativeUrl(page.url) }}">Avvisi</a>
          <a href="{{ '/documenti/' | relativeUrl(page.url) }}">Documenti pubblici</a>
        </nav>
      </div>
    </header>

    <main id="contenuto" class="container main-content">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>&copy; {{ currentYear }} {{ site.name }}.</p>
        <p>
          <a href="{{ '/privacy/' | relativeUrl(page.url) }}">Privacy</a>
          {% if site.email %}<span aria-hidden="true"> · </span><a href="mailto:{{ site.email }}">Contatti</a>{% endif %}
        </p>
      </div>
    </footer>
  </body>
</html>
